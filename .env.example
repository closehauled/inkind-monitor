# inKind monitor configuration. Copy to .env and edit.
#   cp .env.example .env

# ── Recipient (required) ─────────────────────────────────────────────────────
EMAIL_TO=you@example.com
EMAIL_FROM=inkind-monitor@example.com

# ── Email backend ────────────────────────────────────────────────────────────
# Pick ONE. If SMTP_HOST is set, SMTP is used; otherwise Mailgun is used.

# Option A: SMTP (works with any provider, e.g. Gmail/Fastmail app password).
SMTP_HOST=smtp.example.com
SMTP_PORT=587            # 587 = STARTTLS, 465 = implicit SSL
SMTP_USER=you@example.com
SMTP_PASS=your-app-password

# Option B: Mailgun HTTPS API (leave SMTP_HOST empty to use this).
# MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MAILGUN_DOMAIN=mg.example.com

# ── Timezone ─────────────────────────────────────────────────────────────────
# Controls the local hour the schedule fires. Requires tzdata (in the image).
TZ=America/Los_Angeles

# ── Area of interest (worked example: ZIP 97204, downtown Portland) ──────────
INKIND_ZIP=97204
INKIND_AREA_LABEL=Downtown Portland
# Filter centroid: venues within INKIND_RADIUS_MI of this point are included.
INKIND_CENTER_LAT=45.5190
INKIND_CENTER_LNG=-122.6755
INKIND_RADIUS_MI=2
# Sort/display anchor: distances in the email are measured from here.
INKIND_SORT_LAT=45.5188
INKIND_SORT_LNG=-122.6793
INKIND_SORT_LABEL=Pioneer Courthouse Square

# ── Schedule (cron syntax, container local time) ─────────────────────────────
# Defaults: daily change check at 09:00 except Monday; weekly digest Mon 09:00.
# INKIND_CRON_DAILY=0 9 * * 0,2-6
# INKIND_CRON_WEEKLY=0 9 * * 1

# ── Advanced ─────────────────────────────────────────────────────────────────
# INKIND_MAP_URL=https://app.inkind.com/api/v5/map
# DATA_DIR=/data
# Sanity floor: a catalog with fewer locations than this is treated as a
# failed fetch (protects the snapshot from degraded API responses).
# INKIND_MIN_CATALOG=1000
# Email audit log (JSONL of every send attempt). Defaults to email.jsonl in
# DATA_DIR; set a path to move it, or set empty (EMAIL_LOG=) to disable.
# EMAIL_LOG=
